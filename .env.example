# Choose ONE transcription backend.

# === Mode A: Core42 Compass (cloud) ===
OPENAI_API_KEY=your-core42-key
OPENAI_BASE_URL=https://api.core42.ai/v1
OPENCLAW_TRANSCRIPTION_MODEL=whisper-1

# === Mode B: OpenAI direct (cloud) ===
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENCLAW_TRANSCRIPTION_MODEL=whisper-1

# === Mode C: Local Whisper server (no API key, no internet) ===
# Run a local OpenAI-compatible Whisper server on port 9001.
# Recommended: whisper.cpp server. Setup:
#   git clone https://github.com/ggml-org/whisper.cpp /tmp/whisper.cpp
#   cd /tmp/whisper.cpp && make -j
#   bash ./models/download-ggml-model.sh base.en
#   ./build/bin/whisper-server -m models/ggml-base.en.bin --port 9001 --convert
# Then set:
# OCUCLAW_TRANSCRIPTION_BASE_URL=http://127.0.0.1:9001/v1
# OPENCLAW_TRANSCRIPTION_MODEL=whisper-1
# (no OPENAI_API_KEY needed)

# === Mode D: Faster-whisper-server (Python alternative) ===
# pip install faster-whisper-server
# faster-whisper-server --port 9001
# OCUCLAW_TRANSCRIPTION_BASE_URL=http://127.0.0.1:9001/v1
# OPENCLAW_TRANSCRIPTION_MODEL=Systran/faster-whisper-base.en
